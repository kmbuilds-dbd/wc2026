NEXTJS_ENV=development

# bzzoiro Sports Data token — register free at https://sports.bzzoiro.com/register/
# Primary data source for fixtures, results, per-player goal events.
BZZOIRO_TOKEN=

# api-sports.io free tier key — fallback only; free tier blocks 2025+ seasons,
# so this is currently unused. https://dashboard.api-football.com
API_SPORTS_KEY=

# The Odds API free tier key — get one from https://the-odds-api.com
ODDS_API_KEY=

# Any random string. Generate with: openssl rand -hex 32
# Required for cron route handlers to authenticate cron-trigger invocations.
CRON_SECRET=
