NEXTJS_ENV=development

# api-football.com / api-sports.io key. Free tier blocks 2025+ seasons, so
# Pro plan ($19/mo, prepaid, no auto-renewal) is needed for WC 2026. Decision
# deferred until just before Jun 9 kickoff buffer per progress.md.
# https://dashboard.api-football.com
API_SPORTS_KEY=

# The Odds API free tier key — get one from https://the-odds-api.com
ODDS_API_KEY=

# Anthropic key for /api/admin/refresh-squads to search for confirmed squads.
ANTHROPIC_API_KEY=

# Any random string. Generate with: openssl rand -hex 32
# Required for cron route handlers to authenticate cron-trigger invocations.
CRON_SECRET=
